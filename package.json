{
  "name": "dbos-argus",
  "version": "0.0.1",
  "private": true,
  "description": "Self-hosted management console for DBOS Transact — monorepo root.",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "build": "turbo run build --filter=*",
    "dev": "turbo run dev --filter=*",
    "lint": "turbo run lint --filter=*",
    "test": "turbo run test --filter=*",
    "check": "turbo run check --filter=*",
    "gen:protocol": "uv run python scripts/gen_protocol.py"
  },
  "devDependencies": {
    "turbo": "^2.3.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  }
}
