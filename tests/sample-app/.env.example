# Optional. If set, the runner/ops processes connect to DBOS Conductor.
# When this is set, DBOS overrides the literal `argus-runner` / `argus-ops`
# executor_id with a generated UUID at launch.
# DBOS_CONDUCTOR_KEY=dbos_xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx_xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Optional. Override the Postgres URL DBOS Transact reads/writes its system tables on.
# DBOS_SYSTEM_DATABASE_URL=postgresql://argus:argus@localhost:5432/argus
