{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "build/**", ".svelte-kit/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "passThroughEnv": ["ARGUS_DATABASE_URL", "ARGUS_*"]
    },
    "demo": {
      "cache": false,
      "persistent": true,
      "passThroughEnv": ["ARGUS_DATABASE_URL", "ARGUS_*", "DBOS_SYSTEM_DATABASE_URL"]
    },
    "lint": {
      "outputs": []
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "check": {
      "dependsOn": ["^build"],
      "outputs": []
    }
  }
}
