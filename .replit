modules = ["python-3.12", "nodejs-20", "web", "bash"]

[nix]
channel = "stable-25_05"

[env]
NODE_OPTIONS = "--max-old-space-size=4096"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm install && uv sync && pnpm demo"
waitForPort = 5000

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 8090
externalPort = 3000

[agent]
expertMode = true

[deployment]
deploymentTarget = "autoscale"
run = ["uv", "run", "dbos-argus", "--host", "0.0.0.0", "--port", "5000"]
build = ["bash", "-c", "NODE_OPTIONS='--max-old-space-size=4096' pnpm install && uv sync && pnpm --filter console build && mkdir -p packages/server/dbos_argus/_console && cp -r apps/console/build/. packages/server/dbos_argus/_console/"]
