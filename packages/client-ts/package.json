{
  "name": "@dbos-argus/client",
  "version": "0.0.1",
  "description": "TypeScript WebSocket client for DBOS Transact apps connecting to Argus.",
  "license": "MIT",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./protocol": {
      "types": "./src/protocol.ts",
      "default": "./src/protocol.ts"
    }
  },
  "files": ["src"],
  "scripts": {
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "build": "tsc --noEmit"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
